{
  "expo": {
    "name": "Foothill Park",
    "slug": "foothill-park",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "foothill-park",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6DB5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foothilltech.foothillpark",
      "deploymentTarget": "15.5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.foothilltech.foothillpark"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Foothill Park to access your camera to scan licence plates."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "929252d4-3a69-4848-b76e-a75ead5adf03"
      }
    }
  }
}
